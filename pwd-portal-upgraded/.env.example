# ===== Active Directory =====
AD_HOST=dc01.bearhouse.sunsu.local
AD_IP=192.168.0.4
AD_BASE_DN=DC=bearhouse,DC=sunsu,DC=local
AD_USER_OU=DC=bearhouse,DC=sunsu,DC=local
AD_UPN_SUFFIX=bearhouse.sunsu.local
AD_BIND_USER=svc-pwdportal@bearhouse.sunsu.local
AD_BIND_PASSWORD=เปลี่ยนเป็นรหัส_service_account
# required = ตรวจใบรับรอง LDAPS (แนะนำ) | none = ข้าม (เฉพาะตอนทดสอบ)
AD_TLS_VALIDATE=required

# ===== Admin Console (หน้าผู้ดูแลระบบ /admin) =====
# ใส่ sAMAccountName ที่เข้าหน้าแอดมินได้ คั่นด้วยจุลภาค (ว่าง = ปิดโหมดแอดมิน)
ADMIN_USERS=administrator,nont.naraphat
# หรือใช้กลุ่ม AD แทน: ผู้ที่เป็นสมาชิกกลุ่มนี้จะเข้าได้ (ใส่ชื่อกลุ่มหรือบางส่วนของ DN)
ADMIN_GROUP=
# OU เริ่มต้นตอนสร้างผู้ใช้ใหม่ (ว่าง = ใช้ค่า AD_USER_OU)
ADMIN_DEFAULT_OU=

# ===== Lark =====
LARK_DOMAIN=https://open.larksuite.com
LARK_APP_ID=cli_xxxxxxxx
LARK_APP_SECRET=เปลี่ยนเป็น_app_secret

# ===== การแจ้งเตือน =====
NOTIFY_DAYS=14,7,3,1
NOTIFY_HOUR=9
HOST_PORT=8090
PORTAL_URL=https://pwd.bearhouse.sunsu.local
